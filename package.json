{
  "activationEvents": [
    "workspaceContains:tsconfig.json"
  ],
  "categories": [
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "barrel-cellar.showTree",
        "title": "Show Tree"
      }
    ],
    "views": {
      "barrel-cellar": [
        {
          "contextualTitle": "Barrel Files",
          "icon": "resources/extensionicon-dark.png",
          "id": "barrel.cellar",
          "name": "Barrel Files",
          "type": "tree",
          "visibility": "visible"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "icon": "resources/extensionicon.png",
          "id": "barrel-cellar",
          "title": "Barrel Cellar"
        }
      ]
    }
  },
  "dependencies": {
    "typescript": "^5.8.2"
  },
  "description": "A Visual Studio Code extension to manage and visualize barrel files in TypeScript projects.",
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.99.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.23.0"
  },
  "displayName": "Barrel Cellar",
  "engines": {
    "vscode": "^1.99.0"
  },
  "icon": "resources/icon-dark.png",
  "main": "./out/extension.js",
  "name": "barrel-cellar",
  "overrides": {
    "serialize-javascript": "7.0.4"
  },
  "publisher": "TJA",
  "repository": "www.github.com/tjagithub/barrel-cellar.git",
  "scripts": {
    "compile": "tsc -p ./",
    "lint": "eslint src",
    "pretest": "npm run compile && npm run lint",
    "test": "vscode-test",
    "vscode:prepublish": "npm run compile",
    "watch": "tsc -w -p ./"
  },
  "version": "0.0.7"
}